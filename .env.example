# Server
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
LOG_DIR=./logs
LOG_LEVEL=debug

# DB
DB_DSN=postgres://kleos:kleos@localhost:5433/kleos?sslmode=disable

# Redis
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=

# Auth
JWT_SECRET=CHANGE_ME_64_BYTES_HEX
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Crypto
SMTP_CRED_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX

# Codex
CODEX_BIN=/usr/local/bin/codex
CODEX_TIMEOUT=60s
CODEX_HOME=/home/kleos/.codex

# Scraping
GITHUB_TOKEN=
SCRAPER_USER_AGENT=kleos/0.1 (+https://abhiyadav.in/kleos)
SCRAPER_HTTP_TIMEOUT=20s

# Send limits
SEND_RATE_PER_HOUR=20
SEND_RATE_PER_DAY=100
SEND_JITTER_MIN_SECONDS=30
SEND_JITTER_MAX_SECONDS=180

# Warmup defaults
WARMUP_DAY1_LIMIT=5
WARMUP_GROWTH=1.4
WARMUP_CAP=40
WARMUP_DAYS=21

