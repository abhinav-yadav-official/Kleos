# Server
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080
LOG_DIR=./logs
LOG_LEVEL=debug

# DB
DB_DSN=postgres://kleos:kleos@localhost:5433/kleos?sslmode=disable

# Redis
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=

# Auth
JWT_SECRET=CHANGE_ME_64_BYTES_HEX
# Optional: set to the prior JWT_SECRET during a rotation grace period; tokens
# signed under either secret will verify until natural expiry.
JWT_SECRET_PREVIOUS=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Crypto
SMTP_CRED_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX

# Files
RESUME_STORAGE_DIR=./data/resumes

# Scraping
GITHUB_TOKEN=
SCRAPER_USER_AGENT=kleos/0.1 (+https://abhiyadav.in/kleos)
SCRAPER_HTTP_TIMEOUT=20s

# Send limits
SEND_RATE_PER_HOUR=20
SEND_RATE_PER_DAY=100
SEND_JITTER_MIN_SECONDS=30
SEND_JITTER_MAX_SECONDS=180

# Warmup defaults
WARMUP_DAY1_LIMIT=5
WARMUP_GROWTH=1.4
WARMUP_CAP=40
WARMUP_DAYS=21

# Local live sender tests; used by scripts/live_sender_test.sh.
LIVE_TEST_VPS_HOST=vps
LIVE_TEST_API_BASE=https://abhiyadav.in/kleos/api
LIVE_TEST_WORKER_IMAGE=kleos/api:CHANGE_ME_TAG
LIVE_TEST_GMAIL_RECIPIENT=me@abhiyadav.in
LIVE_TEST_FORWARDMAIL_RECIPIENT=abhi.ay.in@gmail.com
LIVE_TEST_GMAIL_SMTP_HOST=smtp.gmail.com
LIVE_TEST_GMAIL_SMTP_PORT=587
LIVE_TEST_GMAIL_SMTP_USER=
LIVE_TEST_GMAIL_SMTP_PASSWORD=
LIVE_TEST_GMAIL_FROM_EMAIL=
LIVE_TEST_GMAIL_FROM_NAME=
LIVE_TEST_FORWARDMAIL_SMTP_HOST=smtp.forwardemail.net
LIVE_TEST_FORWARDMAIL_SMTP_PORT=465
LIVE_TEST_FORWARDMAIL_SMTP_USER=
LIVE_TEST_FORWARDMAIL_SMTP_PASSWORD=
LIVE_TEST_FORWARDMAIL_FROM_EMAIL=me@abhiyadav.in
LIVE_TEST_FORWARDMAIL_FROM_NAME=Abhinav
